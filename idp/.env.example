# Authentik environment variables for the IdP VM.
# Copy this file to .env and fill in the required values.
#
# Required variables:
#   PG_PASS              — PostgreSQL password (must be non-empty)
#   AUTHENTIK_SECRET_KEY — Authentik secret key (must be non-empty)
#
# Optional variables (defaults shown):
#   PG_DB=authentik
#   PG_USER=authentik
#   AUTHENTIK_IMAGE=ghcr.io/goauthentik/server
#   AUTHENTIK_TAG=2026.5.4

PG_DB=authentik
PG_PASS=CHANGE_ME
PG_USER=authentik
AUTHENTIK_SECRET_KEY=CHANGE_ME_RANDOM_64_CHARS
AUTHENTIK_IMAGE=ghcr.io/goauthentik/server
AUTHENTIK_TAG=2026.5.4
