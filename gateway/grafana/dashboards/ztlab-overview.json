{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "row",
      "title": "Access Control",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Auth Decisions (Allow/Deny)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "{job=\"authz-bridge\"} | json | unwrap allowed",
          "legendFormat": "{{allowed}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Deny Reasons",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "{job=\"authz-bridge\"} | json |~ \"denied\"",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Device Posture",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Healthy Devices",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 10 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"device-posture\"} | json | healthy=\"true\" [1h]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Unhealthy Devices",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 10 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"device-posture\"} | json | healthy=\"false\" [1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "title": "Service Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "type": "logs",
      "title": "Recent Access Logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "{job=~\"authz-bridge|demo-app\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["ztlab", "zero-trust"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "ZTLab Overview",
  "uid": "ztlab-overview",
  "version": 1
